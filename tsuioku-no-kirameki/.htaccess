# tsuioku-no-kirameki.com — public_html に配置してください
# www なし・HTTPS 統一（Apache / Xserver 想定）

<IfModule mod_rewrite.c>
  RewriteEngine On

  # www → 正規ホスト（HTTPS）
  RewriteCond %{HTTP_HOST} ^www\.tsuioku-no-kirameki\.com$ [NC]
  RewriteRule ^ https://tsuioku-no-kirameki.com%{REQUEST_URI} [R=301,L]

  # HTTP → HTTPS（正規ホストのみ）
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} ^tsuioku-no-kirameki\.com$ [NC]
  RewriteRule ^ https://tsuioku-no-kirameki.com%{REQUEST_URI} [R=301,L]
</IfModule>

# 静的アセットのブラウザキャッシュ（LP 本体 index.html は短め）
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 day"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/javascript "access plus 7 days"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType audio/mpeg "access plus 1 year"
  ExpiresByType audio/mp4 "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 7 days"
  ExpiresByType application/json "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(ico|png|jpe?g|gif|svg|webp|mp3|m4a|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^site\.webmanifest$|^manifest\.webmanifest$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  <FilesMatch "^robots\.txt$|^sitemap\.xml$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>
